APP_NAME=Private Mailbox Pool
BASE_DOMAIN=example.com
COOKIE_NAME=pmp_session
SESSION_TTL_HOURS=24
MAX_LOGIN_FAILURES=10
LOGIN_BLOCK_MINUTES=15
CF_ACCESS_ENABLED=false
